# Google Analytics
NEXT_PUBLIC_GA_TRACKING_ID=your_ga_tracking_id_here

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# EmailJS — server-side only (used by /api/contact, NOT exposed to the browser)
EMAILJS_SERVICE_ID=your_service_id_here
EMAILJS_TEMPLATE_ID=your_template_id_here
EMAILJS_PUBLIC_KEY=your_public_key_here
# Required for server-side calls — find in EmailJS dashboard → Account → API Keys
# Also enable "Allow non-browser environments" at dashboard.emailjs.com/admin/account/security
EMAILJS_PRIVATE_KEY=your_private_key_here

# reCAPTCHA v3 — server-side only (optional; omit to skip captcha verification)
# Configure to protect the contact form from spam.
# Obtain keys at https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here
